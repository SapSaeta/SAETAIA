# ─── Panel de administración ─────────────────────────────────────────────────

# Contraseña para acceder a /admin (revisión y aprobación de borradores)
ADMIN_SECRET=cambia_esto_por_otra_contrasena_segura

# ─── Seguridad del endpoint de ingesta ───────────────────────────────────────

# Secreto para peticiones manuales a /api/ingest
# POST /api/ingest -H "Authorization: Bearer <valor>"
INGEST_SECRET=cambia_esto_por_un_valor_seguro

# Secreto que Vercel usa para autenticar los cron jobs (lo genera Vercel automáticamente)
# No hace falta configurarlo manualmente: Vercel lo inyecta en producción
# CRON_SECRET=<generado-por-vercel>

# ─── GitHub API (solo necesario para producción en Vercel) ───────────────────
# Permite que el pipeline de ingesta escriba archivos en el repositorio de GitHub,
# lo que desencadena un redeploy automático de Vercel.
#
# Crear un token en: https://github.com/settings/tokens
# Permisos necesarios: repo > contents (read & write)

# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_REPO=tu-usuario/saeta-ia
# GITHUB_BRANCH=main

# ─── GitHub API (opcional — aumenta el rate limit para fuentes de releases) ──
# Sin token: 60 req/hora. Con token: 5000 req/hora.
# El mismo token anterior sirve (solo necesita read:public_repo)
